# =============================================================================
# Application
# =============================================================================
APP_NAME=OneRPM
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

# =============================================================================
# Octane
# =============================================================================
OCTANE_SERVER=swoole

# =============================================================================
# Database (Primary)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=onerpm
DB_USERNAME=onerpm
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_TEST_DATABASE=onerpm_testing

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# =============================================================================
# Nginx
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HOST=example.com

# =============================================================================
# Queue Workers
# =============================================================================
QUEUE_WORKERS=4

# =============================================================================
# Migrations (run on container start)
# =============================================================================
RUN_MIGRATIONS=true

# =============================================================================
# Spotify API
# =============================================================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =============================================================================
# Docker Ports (override defaults)
# =============================================================================
# DB_PORT=3306
# REDIS_PORT=6379
